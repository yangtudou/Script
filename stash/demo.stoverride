name: "我的 DNS 信息瓷砖"
desc: "在 Stash 首页添加一个动态显示 IP 的小方块"

# 1. 定义瓷砖布局 (注意：这里也不要加横杠)
tiles:
  - name: "网络监测"
    script: "my_tile_script"
    update-interval: 30

# 2. 定义脚本模块 (关键点：这里是键值对结构，不要加 -)
script:
  my_tile_script: # <--- 这里绝对不能有横杠
    type: tile
    script-path: "https://raw.githubusercontent.com/yangtudou/Script/main/stash/demo.js"