name: "我的 DNS 信息瓷砖"
desc: "在 Stash 首页添加一个动态显示 IP 的小方块"

# 正确字段是 tiles (注意是复数)
tiles:
  - name: "网络监测"
    # 这里引用 script 模块中定义的脚本名
    script: "my_tile_script"
    # 刷新间隔，单位为秒
    update-interval: 30

# 定义脚本属性
script:
  - name: "my_tile_script"
    type: tile
    script-path: "https://raw.githubusercontent.com/yangtudou/Script/main/stash/demo.js"