name: '添加 秋风取广告规则'
desc: |-
  搬运
  秋风去广告规则
  挺好用
author: |-
  yangtudou[https://github.com/yangtudou]
category: '广告屏蔽'
date: '2026-03-01'
version: '1.0-beta'


rules:
  - RULE-SET,秋风去广告规则,REJECT

rule-providers:
  秋风去广告规则:
    behavior: domain
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/TG-Twilight/AWAvenue-Ads-Rule/main/Filters/AWAvenue-Ads-Rule-Clash.yaml