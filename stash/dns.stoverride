dns:
  default-nameserver: #!replace
    - 223.5.5.5
    - 218.2.2.2
  nameserver: #!replace
    - https://dns.alidns.com/dns-query
    - https://doh.pub/dns-query
  fake-ip-filter:
    - geosite:connectivity-check
    - geosite:private
    - geosite:cn